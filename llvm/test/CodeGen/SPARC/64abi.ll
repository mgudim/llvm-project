define i32 @test_large_stack() {
; CHECK-LABEL: test_large_stack:
; CHECK:         .cfi_startproc
; CHECK-NEXT:  ! %bb.0: ! %entry
; CHECK-NEXT:    sethi 16, %g1
; CHECK-NEXT:    xor %g1, -176, %g1
; CHECK-NEXT:    save %sp, %g1, %sp
; CHECK-NEXT:    .cfi_def_cfa_register %fp
; CHECK-NEXT:    .cfi_window_save
; CHECK-NEXT:    .cfi_register %o7, %i7
; CHECK-NEXT:    sethi 16, %o0
; CHECK-NEXT:    sethi 14, %g1
; CHECK-NEXT:    xor %g1, -1, %g1
; CHECK-NEXT:    add %g1, %fp, %g1
; CHECK-NEXT:    add %g1, 0, %o1
; CHECK-NEXT:    call use_buf
; CHECK-NEXT:    nop
; CHECK-NEXT:    mov %o0, %i0
; CHECK-NEXT:    restore
; CHECK-NEXT:    retl
; CHECK-NEXT:    nop
entry:
  %buffer1 = alloca [16384 x i8], align 8
  %buffer1.sub = getelementptr inbounds [16384 x i8], ptr %buffer1, i32 0, i32 0
  %0 = call i32 @use_buf(i32 16384, ptr %buffer1.sub)
  ret i32 %0
}

