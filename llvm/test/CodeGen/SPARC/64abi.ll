  %rv1 = insertvalue { i32, i32 } undef, i32 %r1, 1
  store i32 0, ptr %p
  %r2 = load i32, ptr %q
  %rv2 = insertvalue { i32, i32 } %rv1, i32 %r2, 0
  ret { i32, i32 } %rv2
}

define void @call_ret_i32_packed(ptr %i0, ptr %i1) {
; CHECK-LABEL: call_ret_i32_packed:
; CHECK:         .cfi_startproc
; CHECK-NEXT:  ! %bb.0:
; CHECK-NEXT:    save %sp, -176, %sp
; CHECK-NEXT:    .cfi_def_cfa_register %fp
; CHECK-NEXT:    .cfi_window_save
; CHECK-NEXT:    .cfi_register %o7, %i7
; CHECK-NEXT:    call ret_i32_packed
; CHECK-NEXT:    nop
; CHECK-NEXT:    srlx %o0, 32, %i2
; CHECK-NEXT:    st %i2, [%i0]
; CHECK-NEXT:    st %o0, [%i1]
; CHECK-NEXT:    restore
; CHECK-NEXT:    retl
; CHECK-NEXT:    nop
  %rv = call { i32, i32 } @ret_i32_packed(i32 undef, i32 undef,
                                          ptr undef, ptr undef)
  %e0 = extractvalue { i32, i32 } %rv, 0
  store i32 %e0, ptr %i0
  %e1 = extractvalue { i32, i32 } %rv, 1
  store i32 %e1, ptr %i1
  ret void
}

