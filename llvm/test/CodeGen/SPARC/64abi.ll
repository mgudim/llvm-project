define inreg float @test_call_libfunc(float %arg0, float %arg1) {
; HARD-LABEL: test_call_libfunc:
; HARD:         .cfi_startproc
; HARD-NEXT:  ! %bb.0: ! %entry
; HARD-NEXT:    save %sp, -192, %sp
; HARD-NEXT:    .cfi_def_cfa_register %fp
; HARD-NEXT:    .cfi_window_save
; HARD-NEXT:    .cfi_register %o7, %i7
; HARD-NEXT:    st %f1, [%fp+2043] ! 4-byte Folded Spill
; HARD-NEXT:    fmovs %f3, %f1
; HARD-NEXT:    call cosf
; HARD-NEXT:    nop
; HARD-NEXT:    st %f0, [%fp+2039] ! 4-byte Folded Spill
; HARD-NEXT:    ld [%fp+2043], %f1 ! 4-byte Folded Reload
; HARD-NEXT:    call sinf
; HARD-NEXT:    nop
; HARD-NEXT:    ld [%fp+2039], %f1 ! 4-byte Folded Reload
; HARD-NEXT:    fmuls %f1, %f0, %f0
; HARD-NEXT:    restore
; HARD-NEXT:    retl
; HARD-NEXT:    nop
;
; SOFT-LABEL: test_call_libfunc:
; SOFT:         .cfi_startproc
; SOFT-NEXT:  ! %bb.0: ! %entry
; SOFT-NEXT:    save %sp, -176, %sp
; SOFT-NEXT:    .cfi_def_cfa_register %fp
; SOFT-NEXT:    .cfi_window_save
; SOFT-NEXT:    .cfi_register %o7, %i7
; SOFT-NEXT:    srl %i1, 0, %o0
; SOFT-NEXT:    call cosf
; SOFT-NEXT:    nop
; SOFT-NEXT:    mov %o0, %i1
; SOFT-NEXT:    srl %i0, 0, %o0
; SOFT-NEXT:    call sinf
; SOFT-NEXT:    nop
; SOFT-NEXT:    mov %o0, %o1
; SOFT-NEXT:    mov %i1, %o0
; SOFT-NEXT:    call __mulsf3
; SOFT-NEXT:    nop
; SOFT-NEXT:    sllx %o0, 32, %i0
; SOFT-NEXT:    restore
; SOFT-NEXT:    retl
; SOFT-NEXT:    nop
entry:
  %0 = tail call inreg float @cosf(float %arg1)
  %1 = tail call inreg float @sinf(float %arg0)
  %2 = fmul float %0, %1
  ret float %2
}

