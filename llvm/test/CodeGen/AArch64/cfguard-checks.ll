; CHECK-LABEL: func_cf_invoke:
; CHECK:       .Lfunc_begin0:
; CHECK-NEXT:  .seh_proc func_cf_invoke
; CHECK-NEXT:    .seh_handler h, @unwind, @except
; CHECK-NEXT:  // %bb.0: // %entry
