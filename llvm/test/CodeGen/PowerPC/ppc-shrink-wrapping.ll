; CHECK-32-NEXT:  L..BB9_3: # %if.end
; CHECK-32-NEXT:    lwz 1, 0(1)
; CHECK-32-NEXT:    lwz 0, 8(1)
; CHECK-32-NEXT:    lwz 31, -4(1)
; CHECK-32-NEXT:    mtlr 0
; CHECK-32-NEXT:    blr
