; DISABLE-64-AIX-NEXT:    mflr 0
; DISABLE-64-AIX-NEXT:    std 31, -8(1)
; DISABLE-64-AIX-NEXT:    stdu 1, -128(1)
; DISABLE-64-AIX-NEXT:    std 0, 144(1)
; DISABLE-64-AIX-NEXT:    mr 31, 1
; DISABLE-64-AIX-NEXT:    bc 12, 20, L..BB9_3
; DISABLE-64-AIX-NEXT:  # %bb.1: # %if.then
; DISABLE-64-AIX-NEXT:    li 3, -16
; DISABLE-64-AIX-NEXT:    addi 4, 31, 128
; DISABLE-64-AIX-NEXT:    stdux 4, 1, 3
; DISABLE-64-AIX-NEXT:    addi 3, 1, 112
; DISABLE-64-AIX-NEXT:    .align 4
; DISABLE-64-AIX-NEXT:  L..BB9_2: # %for.body
; DISABLE-64-AIX-NEXT:    #
; DISABLE-64-AIX-NEXT:    bl .something[PR]
; DISABLE-64-AIX-NEXT:    nop
; DISABLE-64-AIX-NEXT:    b L..BB9_2
; DISABLE-64-AIX-NEXT:  L..BB9_3: # %if.end
; DISABLE-64-AIX-NEXT:    ld 1, 0(1)
; DISABLE-64-AIX-NEXT:    ld 0, 16(1)
; DISABLE-64-AIX-NEXT:    ld 31, -8(1)
; DISABLE-64-AIX-NEXT:    mtlr 0
; DISABLE-64-AIX-NEXT:    blr
entry:
  br i1 undef, label %if.then, label %if.end

if.then:
  %ptr = alloca i32, i32 4
  br label %for.body

for.body:                                         ; preds = %for.body, %entry
  %sum.03 = phi i32 [ 0, %if.then ], [ %add, %for.body ]
